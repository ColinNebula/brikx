{
  "$schema": "https://json.schemastore.org/web-manifest-combined.json",
  "name": "BrickX - Modern Block Puzzle Game",
  "short_name": "BrickX",
  "description": "A modern, colorful block puzzle game with amazing visual effects, combos, and smooth gameplay. Play the ultimate falling-block challenge!",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "theme_color": "#1a0a2e",
  "background_color": "#0a0a1e",
  "categories": ["games", "entertainment"],
  "lang": "en-US",
  "dir": "ltr",
  "prefer_related_applications": false,
  "screenshots": [
    {
      "src": "brikx512.png",
      "sizes": "512x512",
      "type": "image/png",
      "description": "BrickX game in action"
    }
  ],
  "icons": [
    {
      "src": "brikx192.png",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "any"
    },
    {
      "src": "brikx192.png",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "maskable"
    },
    {
      "src": "brikx512.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "any"
    },
    {
      "src": "brikx512.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Start New Game",
      "short_name": "New Game",
      "description": "Start a new game of BrickX",
      "url": "/?action=newgame",
      "icons": [
        {
          "src": "brikx192.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "related_applications": [],
  "pwa_builder": {
    "packageId": "com.brikx.game",
    "certificateInfo": {
      "generateNew": true
    }
  }
}
